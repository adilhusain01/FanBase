# Required to turn POST /api/pay into a real x402-protected USDC testnet endpoint.
X402_PAY_TO=0xYourInjectiveTestnetEvmRecipient
# URL for the self-hosted `facilitator` service. No public facilitator currently supports Injective.
X402_FACILITATOR_URL=
X402_USDC_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d

# Required for the consented X evidence worker (not enabled until this is set).
X_API_BEARER_TOKEN=

# Any OpenAI-compatible chat-completions provider that supports JSON output.
FANBASE_AI_BASE_URL=
FANBASE_AI_API_KEY=
FANBASE_AI_MODEL=
FOOTBALL_DATA_API_TOKEN=
